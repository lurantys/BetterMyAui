generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id          String   @id @db.Uuid
  authUserId  String   @unique @map("auth_user_id") @db.Uuid
  fullName    String   @map("full_name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  semesters UserSemester[]

  @@map("profiles")
}

model UserSemester {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(10)
  year      Int
  term      String   @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses UserCourse[]

  @@unique([userId, type, year, term])
  @@index([userId])
  @@map("user_semesters")
}

model UserCourse {
  id                  String   @id @default(uuid()) @db.Uuid
  semesterId          String   @map("semester_id") @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  code                String   @db.VarChar(20)
  title               String   @db.VarChar(255)
  credits             Decimal  @db.Decimal(3, 1)
  description         String?
  grade               String?  @db.VarChar(5)
  gradePoints         Decimal? @map("grade_points") @db.Decimal(3, 2)
  timeSlots           Json     @default("[]") @map("time_slots")
  color               String?  @db.VarChar(20)
  prerequisiteCourses Json     @default("[]") @map("prerequisite_courses")
  createdAt           DateTime @default(now()) @map("created_at")

  semester UserSemester @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@index([semesterId])
  @@index([userId])
  @@map("user_courses")
}
